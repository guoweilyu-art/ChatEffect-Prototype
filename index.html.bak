<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Chat Effect – Prototype</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{
  font-family:system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
  background:#1a1a1a;
  display:flex;justify-content:center;align-items:center;
  min-height:100vh;overflow:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}

/* ═══════ Phone ═══════ */
.phone{
  width:393px;height:852px;background:#fff;
  border-radius:47px;overflow:hidden;position:relative;
  box-shadow:0 0 0 11px #111,0 0 0 13px #333,0 40px 100px rgba(0,0,0,.5);
}

/* ═══════ Status Bar ═══════ */
.sbar{
  position:absolute;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:space-between;align-items:center;
  padding:16px 30px 0;height:54px;
  font-size:16px;font-weight:600;letter-spacing:-.3px;
  pointer-events:none;
}
.sbar.dark{color:#000}.sbar.light{color:#fff}
.sbar-r{display:flex;gap:5px;align-items:center}

/* ═══════ Home Indicator ═══════ */
.hind{
  position:absolute;bottom:8px;left:50%;transform:translateX(-50%);
  width:134px;height:5px;border-radius:100px;z-index:500;
}
.hind.dark{background:#000}.hind.light{background:rgba(255,255,255,.6)}

/* ═══════ Screens ═══════ */
.scr{
  position:absolute;inset:0;
  opacity:0;pointer-events:none;
  transition:opacity .3s ease,transform .3s ease;
  transform:translateX(30px);
}
.scr.on{opacity:1;pointer-events:auto;transform:none}

/* ═══════════════════════════════════════
   GEM STORE
   ═══════════════════════════════════════ */
.gs{background:#fff;overflow:hidden;padding-top:54px;display:flex;flex-direction:column}

/* Fixed header */
.gs-header{flex-shrink:0;background:#fff;position:relative;z-index:10}

/* Nav */
.gs-nav{display:flex;align-items:center;padding:0 16px;height:44px;position:relative}
.gs-back{
  width:32px;height:32px;display:flex;align-items:center;justify-content:center;
  background:#fff;border:none;cursor:pointer;flex-shrink:0;border-radius:999px;
}
.gs-back svg{width:20px;height:20px}
.gs-nav-badges{display:flex;gap:4px;margin-left:auto;border-radius:999px;overflow:hidden}
.badge{
  display:flex;align-items:center;gap:4px;
  background:#f3f3f3;border-radius:4px;
  padding:4px 8px 4px 4px;
  font-size:14px;line-height:19px;letter-spacing:-0.15px;font-weight:600;color:#1c1c1c;
}
.badge img{width:32px;height:32px;border-radius:999px}

/* Title — text-650 bold */
.gs-title{
  font-size:20px;line-height:28px;letter-spacing:0.1px;font-weight:700;
  padding:12px 16px 10px;color:#111;
}

/* Tabs — text-400 semibold */
.gs-tabs{
  display:flex;padding:0 16px;
  border-bottom:1px solid #e5e5e5;
}
.gs-tab{
  padding:10px 0;margin-right:20px;
  font-size:16px;line-height:21px;letter-spacing:-0.31px;
  font-weight:600;color:var(--tabs-inactive, #AAAAAA);
  cursor:pointer;border-bottom:2.5px solid transparent;
  margin-bottom:-1px;white-space:nowrap;
}
.gs-tab.on{color:#111;font-weight:700;border-bottom-color:#111}

/* Body — scrollable area */
.gs-body{padding:16px 16px 50px;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1}
.gs-body::-webkit-scrollbar{display:none}

/* Section Header — text-500 bold */
.sh{display:flex;justify-content:space-between;align-items:center}
.sh-t{font-size:18px;line-height:23px;letter-spacing:-0.44px;font-weight:600;color:#121212}
.sh-a{
  font-size:14px;line-height:22px;letter-spacing:-0.2px;font-weight:600;color:#111;
  cursor:pointer;display:flex;align-items:center;gap:2px;
}
.sh-a svg{width:24px;height:24px}
.sh-sub{font-size:13px;line-height:18px;letter-spacing:-0.11px;color:#999;margin:3px 0 12px}

/* ── Jumbotron Card ── */
.jcard{
  border-radius:16px;overflow:hidden;
  height:316px;position:relative;
  background:url('../Assets/Background%20image.png') center/cover no-repeat;
  margin-bottom:14px;
}
.jcard-img{
  position:absolute;top:0;left:0;
  width:100%;height:auto;
  pointer-events:none;
}
.jcard-bot{
  position:absolute;bottom:0;left:0;right:0;
  display:flex;justify-content:space-between;align-items:flex-end;
  padding:14px 16px 16px;
}
.jcard-price{
  display:flex;align-items:center;gap:4px;
  font-size:13px;line-height:18px;letter-spacing:-0.11px;
  font-weight:600;color:#fffff4;margin-bottom:3px;
}
.jcard-price img{width:20px;height:20px}
.jcard-name{font-size:18px;line-height:23px;letter-spacing:-0.59px;font-weight:700;color:#fffff4}
/* "View" button — design system primary, yellow */
.jcard-btn{
  display:inline-flex;align-items:center;justify-content:center;
  width:108px;height:44px;border-radius:999px;
  font-size:16px;line-height:24px;letter-spacing:-0.41px;font-weight:600;
  background:#ffe414;color:#000;border:1px solid transparent;
  cursor:pointer;
}

/* Jumbotron thumbnails: scrollable, 8px gaps, 1:1 */
.jthumbs{
  display:flex;gap:8px;margin-bottom:16px;
  overflow-x:scroll;-webkit-overflow-scrolling:touch;
  padding:0 16px;margin-left:-16px;margin-right:-16px;
}
.jthumbs::-webkit-scrollbar{display:none}
.jthumb{
  width:calc((361px - 24px) / 4);min-width:calc((361px - 24px) / 4);
  aspect-ratio:1/1;
  border-radius:16px;
  background:#F5F5F5;overflow:visible;
  display:flex;align-items:center;justify-content:center;
  position:relative;flex-shrink:0;
}
.jthumb.selected{background:#1c1c1c}
.jthumb img{width:70%;height:70%;object-fit:contain}
.jthumb-gem{
  position:absolute;bottom:8px;left:8px;
  width:20px!important;height:20px!important;
}
.jthumb.selected .jthumb-gem{display:none}

/* ── Chat Effect ── */
.ce-hdr{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.ce-hdr .ce-title{font-size:18px;line-height:23px;letter-spacing:-0.44px;font-weight:600;color:#121212}
.beta-tag{
  background:#ffe414;font-size:12px;line-height:12px;font-weight:600;
  padding:4px 8px;border-radius:4px;color:#000;letter-spacing:0;
}
.ce-banner{
  border-radius:16px;overflow:hidden;
  height:186px;position:relative;cursor:pointer;
  isolation:isolate;-webkit-mask-image:-webkit-radial-gradient(white,black);
}
.ce-banner-bg{
  position:absolute;inset:0;
  background:url('../Assets/Background%20image.png') center/cover no-repeat;
}
.ce-banner-bg::before{
  content:'';position:absolute;inset:0;
  background:rgba(0,0,0,0.8);
}
.ce-banner-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(0,0,0,0) 0%,rgba(0,0,0,0.6) 100%);
  backdrop-filter:blur(32px);-webkit-backdrop-filter:blur(32px);
}
.ce-main{
  position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
  font-size:36px;line-height:43px;letter-spacing:0.37px;
  font-weight:700;font-style:italic;white-space:nowrap;
  background:linear-gradient(90deg,#a3fff6,#f9ff8f);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.ce-hearts{position:absolute;left:30px;top:18px}
.ce-hearts img{width:73px;height:37px}
.ce-thank{position:absolute;left:226px;top:25px}
.ce-thank img{height:28px;width:auto}
.ce-hey{position:absolute;left:-27px;top:130px}
.ce-hey img{height:53px;width:auto}
.ce-anycard{position:absolute;left:calc(50% + 70px);top:calc(50% + 35px)}
.ce-anycard img{width:122px;height:41px}

/* ── Reaction ── */
.r-sec{margin-top:16px}
.r-grid{display:flex;gap:10px;overflow-x:scroll;padding:12px 16px 4px 16px;margin-left:-16px;margin-right:-16px;-webkit-overflow-scrolling:touch}
.r-grid::-webkit-scrollbar{display:none}
.r-card{
  width:140px;min-width:140px;flex-shrink:0;
  background:#f3f3f3;border-radius:12px;
  padding:16px 12px;text-align:center;
  display:flex;flex-direction:column;align-items:center;gap:8px;
}
.r-card img{width:96px;height:96px;object-fit:contain}
.r-card-btm{display:flex;flex-direction:column;gap:2px;align-items:center;width:100%}
.r-name{font-size:12px;line-height:16px;letter-spacing:0;font-weight:600;color:#1c1c1c;height:24px;display:flex;align-items:center;justify-content:center}
.r-price{
  display:flex;align-items:center;justify-content:center;gap:4px;
  font-size:12px;line-height:16px;letter-spacing:0;font-weight:600;color:#1c1c1c;
  padding:4px 12px;
}
.r-price img{width:16px;height:16px;flex-shrink:0}
.r-price .old{text-decoration:line-through;color:#7f7f7f;font-weight:600;font-size:12px}

/* ── Coupon ── */
.c-sec{margin-top:16px}
.c-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.c-info-btn{
  width:16px;height:16px;border:none;
  display:flex;align-items:center;justify-content:center;
  color:#121212;cursor:pointer;background:none;padding:0;
}
.c-info-btn svg{width:16px;height:16px}
.c-list{display:flex;flex-direction:column}
.c-item{
  display:flex;gap:12px;align-items:flex-start;
  padding:16px 0;border-bottom:1px solid rgba(0,0,0,0.05);
}
.c-item:first-child{padding-top:0}
.c-item:last-child{border-bottom:none;padding-bottom:0}
.c-item-img{
  width:140px;height:140px;flex-shrink:0;border-radius:8px;
  background:url('../Assets/Coupon%20background.png') center/cover no-repeat;
  position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.c-price-label{
  font-size:48px;font-weight:900;color:#1c1c1c;line-height:1;
}
.c-item-body{
  flex:1;display:flex;flex-direction:column;gap:8px;min-width:0;
}
.c-title-meta{display:flex;flex-direction:column;gap:2px}
.c-name{font-size:14px;line-height:19px;letter-spacing:-0.15px;font-weight:600;color:#000}
.c-qty{font-size:13px;line-height:18px;letter-spacing:-0.08px;font-weight:400;color:#7f7f7f}
.c-cprice{display:flex;align-items:center;gap:4px;font-size:14px;line-height:19px;letter-spacing:-0.15px;font-weight:600;color:#1c1c1c}
.c-cprice img{width:16px;height:16px}
.c-cprice .old{text-decoration:line-through;color:#7f7f7f;font-weight:600;font-size:16px;line-height:21px;letter-spacing:-0.31px}

/* ═══════════════════════════════════════
   INTRO BOTTOM SHEET
   ═══════════════════════════════════════ */
.ov{
  position:absolute;inset:0;z-index:50;
  background:rgba(0,0,0,.4);
  opacity:0;pointer-events:none;transition:opacity .3s ease;
}
.ov.on{opacity:1;pointer-events:auto}

.bs{
  position:absolute;bottom:0;left:0;right:0;z-index:51;
  background:#fff;border-radius:24px 24px 0 0;
  transform:translateY(100%);
  transition:transform .42s cubic-bezier(.32,.72,0,1);
  padding-bottom:34px;overflow:hidden;
}
.bs.on{transform:translateY(0)}
.bs-handle{width:40px;height:4px;border-radius:30px;background:#e6e6e6;margin:8px auto 12px}
.bs-body{display:flex;flex-direction:column;gap:24px;align-items:center;padding:0 0 12px}

.cp-card{
  width:345px;height:230px;border-radius:16px;overflow:hidden;
  position:relative;box-shadow:0 4px 8px rgba(0,0,0,0.02);
  background:#2d2d2d;isolation:isolate;-webkit-mask-image:-webkit-radial-gradient(white,black);
}
.cp-card-bg{
  position:absolute;inset:0;
  background:url('../Assets/Background%20image.png') center/cover no-repeat;
}
.cp-card-bg::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,0.8)}
.cp-card-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(0,0,0,0) 0%,rgba(0,0,0,0.6) 100%);
  backdrop-filter:blur(32px);-webkit-backdrop-filter:blur(32px);
}
.cp-thread{
  position:absolute;left:29px;top:50%;transform:translateY(-50%);
  width:287px;z-index:2;
}
.cp-msg-mid{position:relative}
.cp-msg-mid .cp-highlight{
  position:absolute;top:-2px;bottom:-2px;left:0;right:0;border-radius:6px;
  background:linear-gradient(90deg,rgba(255,255,255,0),#fff);
  opacity:0.32;z-index:0;
}
.cp-msg-mid .cp-msg{position:relative;z-index:1}
.cp-msg-top,.cp-msg-bot{padding:0}
.cp-msg-top{margin-bottom:10px}
.cp-msg-bot{margin-top:10px}
.cp-msg{display:flex;gap:8px;align-items:flex-start;padding:0}
.cp-msg.dim{opacity:0.6}
.cp-av{width:32px;height:32px;border-radius:50%;overflow:hidden;flex-shrink:0;margin-top:2px}
.cp-av img{width:100%;height:100%;object-fit:cover}
.cp-user{font-size:14px;line-height:19px;letter-spacing:-0.15px;color:rgba(255,255,255,0.8);font-weight:400;
  text-shadow:0 1px 1px rgba(0,0,0,0.25);height:18px;overflow:hidden}
.cp-text{font-size:13px;line-height:18px;letter-spacing:-0.08px;color:#fff;font-weight:600;
  text-shadow:0 1px 1px rgba(0,0,0,0.25)}
.cp-text.gfx{
  background:linear-gradient(90deg,#a3fff6,#f9ff8f);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;font-weight:600;font-size:13px;line-height:21px;letter-spacing:-0.31px;
}

.bs-texts{padding:0 40px;text-align:center;display:flex;flex-direction:column;gap:12px}
.bs-title{
  font-size:28px;line-height:34px;letter-spacing:0.38px;font-weight:600;
  color:#1c1c1c;
}
.bs-desc{
  font-size:16px;line-height:21px;letter-spacing:-0.31px;
  color:#545454;font-weight:400;
}
.bs-tray{padding:16px 16px 0;width:100%;box-sizing:border-box}
.bs-btn{
  width:100%;display:flex;align-items:center;justify-content:center;
  height:48px;background:#1c1c1c;color:#fff;
  border:none;border-radius:999px;
  font-size:16px;line-height:20px;letter-spacing:-0.41px;font-weight:600;
  cursor:pointer;font-family:inherit;
}

/* ═══════════════════════════════════════
   TRANSITION OVERLAY
   ═══════════════════════════════════════ */
#transOverlay{position:absolute;inset:0;z-index:400;pointer-events:none;opacity:0;overflow:hidden}
#transOverlay.visible{opacity:1}
.scr.no-trans{transition:none!important}
#transOverlay .trans-bg{
  position:absolute;
  background:url('../Assets/Background%20image.png') center/cover no-repeat;
  transition:all .4s cubic-bezier(0.4,0,0.2,1);
}
#transOverlay .trans-dark{
  position:absolute;inset:0;
  background:rgba(0,0,0,0.8);
  transition:opacity .4s cubic-bezier(0.4,0,0.2,1);
}
#transOverlay .trans-blur{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(0,0,0,0) 0%,rgba(0,0,0,0.6) 100%);
  backdrop-filter:blur(32px);-webkit-backdrop-filter:blur(32px);
  transition:opacity .4s cubic-bezier(0.4,0,0.2,1);
}

/* ═══════════════════════════════════════
   EFFECT SCREENS (shared)
   ═══════════════════════════════════════ */
.dark-bg{
  position:absolute;inset:0;
  background:url('../Assets/Background%20image.png') center/cover no-repeat;
}

.enav{
  display:flex;align-items:center;padding:54px 16px 0;position:relative;z-index:2;height:98px;
}
.enav-back{
  width:32px;height:32px;display:flex;align-items:center;justify-content:center;
  background:#121212;border:none;cursor:pointer;border-radius:999px;flex-shrink:0;
  position:relative;z-index:1;
}
.enav-back svg{width:20px;height:20px}
.enav-title{
  position:absolute;left:0;right:0;top:54px;height:44px;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;line-height:21px;letter-spacing:-0.41px;font-weight:600;color:#fff;
  pointer-events:none;
}
.enav-gem{
  display:flex;align-items:center;gap:4px;margin-left:auto;
  font-size:14px;line-height:19px;letter-spacing:-0.15px;font-weight:600;color:#fff;
  padding:4px 8px 4px 4px;border-radius:999px;
  position:relative;z-index:1;
}
.enav-gem img{width:32px;height:32px}

/* Chat messages on dark screen */
.echat{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;z-index:2;
}
.echat-inner{
  display:flex;flex-direction:column;gap:24px;
  max-width:calc(100% - 72px);
}
.em{padding:0 8px}
.em-u{font-size:14px;line-height:19px;letter-spacing:-0.15px;color:rgba(255,255,255,1);margin-bottom:0;font-weight:400;
  text-shadow:0 1px 1px rgba(0,0,0,0.25);height:18px;overflow:hidden}
.em-t{font-size:36px;font-weight:600;line-height:43px;letter-spacing:0.37px;
  text-shadow:0 1px 1px rgba(0,0,0,0.25)}
.em.muted{opacity:0.36}
.em-t.white{color:#fff}
.em-t.grad{
  background:linear-gradient(90deg,#a3fff6,#f9ff8f);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.em-t.outl{
  color:#fff;font-weight:760;
  font-variation-settings:'wdth' 132;font-stretch:expanded;
  -webkit-text-stroke:3px transparent;paint-order:stroke fill;
  position:relative;
}
.em-t.outl::before{
  content:attr(data-text);position:absolute;top:0;left:0;
  font-weight:inherit;font-size:inherit;line-height:inherit;letter-spacing:inherit;
  font-variation-settings:inherit;font-stretch:inherit;
  -webkit-text-fill-color:transparent;
  -webkit-text-stroke:3px transparent;
  background:linear-gradient(180deg,#9CE3FF,#688CFF);
  -webkit-background-clip:text;background-clip:text;
  z-index:-1;
}
.em-t.inbox{color:#fff;font-weight:600}
.em-box{
  border:2.5px solid #22C55E;border-radius:12px;
  padding:6px 14px 10px;display:inline-block;position:relative;
}
.em-box::after{
  content:'';position:absolute;bottom:-8px;left:-8px;
  width:13px;height:13px;border-radius:3px;background:#22C55E;
}

/* Effect tabs */
.etabs{
  display:flex;gap:0;overflow-x:auto;-webkit-overflow-scrolling:touch;
  position:relative;z-index:2;
  scroll-snap-type:x mandatory;
}
.etabs::before,.etabs::after{content:'';flex-shrink:0}
.etabs::-webkit-scrollbar{display:none}
.etab{
  padding:10px 8px;border-radius:999px;height:28px;box-sizing:content-box;
  font-size:14px;font-weight:600;cursor:pointer;
  white-space:nowrap;color:rgba(255,255,255,1);
  background:transparent;border:none;font-family:inherit;
  transition:all .3s ease-in-out;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  scroll-snap-align:center;
  margin:0 8px;
}
.etab.on{padding:10px 16px;font-size:20px;line-height:18px;margin:0 28px}
.etab-grad{
  background:linear-gradient(90deg,#a3fff6,#f9ff8f);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.etabs-wrap{position:relative;z-index:2;margin-left:-16px;margin-right:-16px}
.etab-indicator{
  position:absolute;top:50%;left:50%;
  min-width:140px;height:48px;border-radius:999px;
  background:rgba(255,255,255,0.2);
  transition:width .3s ease-in-out,transform .3s ease-in-out;
  pointer-events:none;z-index:0;
}
.etab.it{
  font-weight:760;font-variation-settings:'wdth' 132;font-stretch:expanded;
  color:#fff;position:relative;
  -webkit-text-stroke:3px transparent;paint-order:stroke fill;
}
.etab.it::before{
  content:attr(data-text);position:absolute;
  font-weight:inherit;font-size:inherit;line-height:inherit;letter-spacing:inherit;
  font-variation-settings:inherit;font-stretch:inherit;
  -webkit-text-fill-color:transparent;
  -webkit-text-stroke:3px transparent;
  background:linear-gradient(180deg,#9CE3FF,#688CFF);
  -webkit-background-clip:text;background-clip:text;
  z-index:-1;
}
.etab-dyn{display:inline-flex;align-items:flex-end;gap:0}
.etab-sm{font-size:8px;line-height:14px;letter-spacing:-0.08px;font-weight:600}
.etab.on .etab-sm{font-size:11px}
.etab-sw{
  height:48px;border-radius:999px;cursor:pointer;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  padding:0 8px;scroll-snap-align:center;
  margin:0 8px;transition:all .3s ease-in-out;
}
.etab-sw.on{margin:0 28px}
.etab-sw img{width:48px;height:auto;transition:width .3s ease-in-out}
.etab-sw.on img{width:68px}

/* Bottom controls */
.ebot{padding:16px 16px 34px;position:relative;z-index:2;display:flex;flex-direction:column;gap:10px}
.edisc{font-size:12px;line-height:16px;color:#aaa;text-align:center;font-weight:400}
.ebuy{
  width:100%;height:44px;
  background:rgba(255,255,255,0.2);color:#fff;
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border:none;border-radius:999px;
  font-size:16px;line-height:20px;letter-spacing:-0.41px;font-weight:600;
  cursor:pointer;font-family:inherit;
  display:flex;align-items:center;justify-content:center;gap:4px;
}
.ebuy img{width:20px;height:20px}
.eexp{font-size:14px;color:rgba(255,255,255,.35);text-align:center;margin-top:14px}
.eexp span{color:#22C55E}

/* ── Edit mode on preview screen ── */
.em.muted,.em-u,.enav,.ebot .edisc,.ebot .ebuy,.ebot>div[style]{
  transition:opacity .4s ease-in-out,transform .4s ease-in-out;
}
.scr.editing .em.muted{opacity:0;pointer-events:none;height:0;overflow:hidden;transition:opacity .4s ease-in-out}
.scr.editing .em-u{opacity:0;height:0;overflow:hidden;transition:opacity .4s ease-in-out}
.scr.editing .ebot .edisc{display:none}
.scr.editing .ebot .ebuy{display:none}
.scr.editing .ebot>div[style="height:64px"]{display:none}
.scr.editing .enav{opacity:0;pointer-events:none;transition:opacity .4s ease-in-out}
.ep-kb{overflow:hidden;max-height:0;transition:max-height .4s ease-in-out;z-index:2;margin:0 -16px}
.scr.editing .ebot{padding-bottom:0;gap:0}
.echat{transition:padding .4s ease-in-out}
.scr.editing .echat{padding:36px}
.echat-inner{transition:max-width .4s ease-in-out}
.scr.editing .echat-inner{max-width:100%}
.etabs-wrap{transition:margin .4s ease-in-out}
.scr.editing .ep-kb{max-height:400px;margin-top:20px}
.ep-cursor{
  display:inline-block;width:2px;height:0.9em;background:#fff;
  vertical-align:baseline;margin-left:2px;
  animation:blink 1s step-end infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.ep-kb .kb{position:relative;padding-bottom:45px}
.em-t[contenteditable]{outline:none;caret-color:rgba(255,255,255,.7);cursor:text;-webkit-user-select:text;user-select:text}

/* ═══════════════════════════════════════
   TYPING SCREEN
   ═══════════════════════════════════════ */
.ts-area{
  position:absolute;top:50%;left:24px;right:24px;
  transform:translateY(-100%);z-index:2;
}
.ts-ph{
  position:absolute;pointer-events:none;
  font-size:34px;font-weight:700;color:rgba(255,255,255,.25);
  letter-spacing:-.5px;
}
.ts-inp{
  font-size:34px;font-weight:700;line-height:1.3;
  outline:none;min-height:44px;
  caret-color:rgba(255,255,255,.7);
  letter-spacing:-.5px;word-break:break-word;
}
.ts-inp.g-s{
  background:linear-gradient(90deg,#A8E063,#56AB2F,#22C55E);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.ts-inp.o-s{color:transparent;-webkit-text-stroke:2px #22C55E;font-weight:900}
.ts-inp.d-s{color:#22C55E}

.ts-tabs{
  position:absolute;z-index:10;left:0;right:0;
  display:flex;gap:2px;justify-content:center;padding:0 20px;
}

/* iOS Keyboard */
.kb{
  position:absolute;bottom:0;left:0;right:0;z-index:10;
  background:#D1D4DB;padding:10px 3px 0;
}
.kr{display:flex;justify-content:center;gap:6px;margin-bottom:10px;padding:0 3px}
.kr:last-child{margin-bottom:0;padding-bottom:20px}
.k{
  background:#FCFCFE;border-radius:5px;min-width:34px;height:43px;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;font-weight:400;cursor:pointer;
  box-shadow:0 1px 0 rgba(0,0,0,.3);user-select:none;
  font-family:inherit;color:#111;
}
.k.sp{min-width:42px;font-size:14px;font-weight:500;background:#ACB2BC;color:#111;box-shadow:0 1px 0 rgba(0,0,0,.25)}
.k.spc{flex:1;font-size:16px}
.k.dn{background:#007AFF;color:#fff;min-width:74px;font-size:16px;font-weight:600;box-shadow:0 1px 0 rgba(0,0,0,.25)}
.kb-extra{display:flex;justify-content:space-between;padding:6px 20px 8px;font-size:22px}

/* ═══════════════════════════════════════
   TOAST
   ═══════════════════════════════════════ */
.toast{
  position:absolute;top:52px;left:10px;right:10px;z-index:600;
  background:rgba(255,255,255,.97);
  backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  border-radius:18px;padding:14px 16px;
  display:flex;align-items:center;gap:12px;
  transform:translateY(-200%);
  transition:transform .45s cubic-bezier(.32,.72,0,1);
}
.toast.show{transform:translateY(0)}
.toast-ic{
  width:40px;height:40px;border-radius:10px;
  background:linear-gradient(135deg,#34D399,#059669);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:800;color:#fff;flex-shrink:0;
  letter-spacing:-.5px;
}
.toast-tt{font-size:15px;font-weight:700;color:#1c1c1c;margin-bottom:2px}
.toast-st{font-size:13px;color:#666;line-height:1.35}
</style>
</head>
<body>

<div class="phone" id="app">

<!-- Status Bar -->
<div class="sbar dark" id="sbar">
  <span>9:41</span>
  <div class="sbar-r">
    <svg width="18" height="12" fill="currentColor"><rect x="1" y="3.5" width="2.5" height="8.5" rx=".7" opacity=".3"/><rect x="5" y="2" width="2.5" height="10" rx=".7" opacity=".5"/><rect x="9" y=".5" width="2.5" height="11.5" rx=".7" opacity=".7"/><rect x="13" y="0" width="2.5" height="12" rx=".7"/></svg>
    <svg width="17" height="12" fill="currentColor"><path d="M8.5 2.8a9 9 0 0 0-6 2.3L.8 3.4A11 11 0 0 1 8.5.5a11 11 0 0 1 7.7 2.9l-1.7 1.7a9 9 0 0 0-6-2.3z" opacity=".35"/><path d="M8.5 5.8a6 6 0 0 0-4 1.6L2.8 5.7a8 8 0 0 1 5.7-2.2 8 8 0 0 1 5.7 2.2l-1.7 1.7a6 6 0 0 0-4-1.6z" opacity=".65"/><path d="M8.5 8.8c-.9 0-1.7.3-2.3.9L8.5 12l2.3-2.3a3.3 3.3 0 0 0-2.3-.9z"/></svg>
    <svg width="28" height="13" fill="currentColor"><rect x=".5" y=".5" width="23" height="12" rx="3.5" fill="none" stroke="currentColor" stroke-width="1" opacity=".35"/><rect x="25" y="4" width="2" height="5" rx="1" opacity=".4"/><rect x="2" y="2" width="20" height="9" rx="2.5"/></svg>
  </div>
</div>
<div class="hind dark" id="hind"></div>

<!-- ═══════════════════════════════════════
     SCREEN 1: GEM STORE
     ═══════════════════════════════════════ -->
<div class="scr gs on" id="scrGS">
  <div class="gs-header">
  <!-- Nav -->
  <div class="gs-nav">
    <button class="gs-back"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="#111" fill-rule="evenodd" d="M16.972 2.293a.97.97 0 0 1 0 1.414L8.333 12l8.639 8.293a.97.97 0 0 1 0 1.414c-.407.39-1.067.39-1.473 0L6.86 13.414a1.944 1.944 0 0 1 0-2.828L15.5 2.293a1.073 1.073 0 0 1 1.473 0" clip-rule="evenodd"/></svg></button>
    <div class="gs-nav-badges">
      <div class="badge"><img src="../Assets/Whatnot%20credit%20icon.png" alt="coins">$0</div>
      <div class="badge"><img src="../Assets/Gem%20icon.png" alt="gems">123,200,200</div>
    </div>
  </div>

  <!-- Title -->
  <div class="gs-title">Earn Rewards & Unlock Perks</div>

  <!-- Tabs -->
  <div class="gs-tabs">
    <div class="gs-tab">Referrals</div>
    <div class="gs-tab">Challenges</div>
    <div class="gs-tab on">Gem Store</div>
    <div class="gs-tab">Coupons</div>
  </div>
  </div><!-- /gs-header -->

  <!-- Scrollable body -->
  <div class="gs-body">

    <!-- Jumbotron -->
    <div class="sh"><span class="sh-t">Jumbotron</span><span class="sh-a">View All <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M9.293 17.707a1 1 0 0 1 0-1.414L13.586 12 9.293 7.707a1 1 0 1 1 1.414-1.414L15 10.586a2 2 0 0 1 0 2.828l-4.293 4.293a1 1 0 0 1-1.414 0" clip-rule="evenodd"/></svg></span></div>
    <div class="sh-sub">Live purchase announcements</div>

    <div class="jcard">
      <img class="jcard-img" src="../Assets/Smile%20face%20preview.png" alt="">
