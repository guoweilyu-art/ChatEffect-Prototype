  </div>
</div>

<!-- ═══════════════════════════════════════
     SCREEN 2: EFFECT PREVIEW
     ═══════════════════════════════════════ -->
<div class="scr" id="scrEP" style="display:flex;flex-direction:column">
  <div class="dark-bg"></div>
  <div class="enav">
    <button class="enav-back" id="epBack"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="#fff" fill-rule="evenodd" d="M16.972 2.293a.97.97 0 0 1 0 1.414L8.333 12l8.639 8.293a.97.97 0 0 1 0 1.414c-.407.39-1.067.39-1.473 0L6.86 13.414a1.944 1.944 0 0 1 0-2.828L15.5 2.293a1.073 1.073 0 0 1 1.473 0" clip-rule="evenodd"/></svg></button>
    <div class="enav-title">Chat Effect</div>
