      <div class="jthumb"><img src="../Assets/magic%20icon.png" alt=""><img class="jthumb-gem" src="../Assets/Gem%20icon.png" alt=""></div>
      <div class="jthumb"><img src="../Assets/smile%20face%20icon.png" alt=""><img class="jthumb-gem" src="../Assets/Gem%20icon.png" alt=""></div>
      <div class="jthumb"><img src="../Assets/crown%20icon.png" alt=""><img class="jthumb-gem" src="../Assets/Gem%20icon.png" alt=""></div>
      <div class="jthumb"><img src="../Assets/holiday%20icon.png" alt=""><img class="jthumb-gem" src="../Assets/Gem%20icon.png" alt=""></div>
      <div class="jthumb"><img src="../Assets/magic%20icon.png" alt=""><img class="jthumb-gem" src="../Assets/Gem%20icon.png" alt=""></div>
    </div>

    <!-- Chat Effect -->
