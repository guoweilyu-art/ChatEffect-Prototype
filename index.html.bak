      <div class="etab-sw"><img src="../Assets/Hahaha.svg" alt="Hahaha"></div>
      <div class="etab-sw" data-e="pink"><img src="../Assets/PinkBubble.svg" alt="Pink"></div>
      </div>
    </div>
    <div style="height:64px"></div>
    <div class="edisc">This chat effect will expire <span style="color:#34C759">7 days</span> after purchase.</div>
    <button class="ebuy" id="buyBtn">Buy for&nbsp;<img src="../Assets/Gem%20icon.png" alt="">&nbsp;400</button>
    <div class="ep-kb">
      <div class="kb">
        <div class="kr">
          <div class="k ek">Q</div><div class="k ek">W</div><div class="k ek">E</div><div class="k ek">R</div><div class="k ek">T</div><div class="k ek">Y</div><div class="k ek">U</div><div class="k ek">I</div><div class="k ek">O</div><div class="k ek">P</div>
        </div>
        <div class="kr" style="padding:0 18px">
          <div class="k ek">A</div><div class="k ek">S</div><div class="k ek">D</div><div class="k ek">F</div><div class="k ek">G</div><div class="k ek">H</div><div class="k ek">J</div><div class="k ek">K</div><div class="k ek">L</div>
        </div>
        <div class="kr">
          <div class="k sp ek">⇧</div>
          <div class="k ek">Z</div><div class="k ek">X</div><div class="k ek">C</div><div class="k ek">V</div><div class="k ek">B</div><div class="k ek">N</div><div class="k ek">M</div>
          <div class="k sp ek">⌫</div>
        </div>
        <div class="kr">
          <div class="k sp ek">123</div>
          <div class="k spc ek">space</div>
          <div class="k dn ek">Done</div>
        </div>
      </div>
    </div>
  </div>
  <div class="ov" id="ov"></div>
  <div class="bs" id="bsheet">
    <div class="bs-handle"></div>
    <div class="bs-body">
      <div class="cp-card">
        <div class="cp-card-bg"></div>
        <div class="cp-thread">
          <div class="cp-msg dim cp-msg-top">
            <div class="cp-av"><img src="../Assets/Placeholder%20avatar.png" alt=""></div>
            <div><div class="cp-user">andy</div><div class="cp-text">yay! 🥳🥳🥳</div></div>
          </div>
          <div class="cp-msg-mid">
            <div class="cp-highlight"></div>
            <div class="cp-msg">
              <div class="cp-av"><img src="../Assets/User%20avatar.png" alt=""></div>
              <div><div class="cp-user">labubunation</div><div class="cp-text gfx">Happy Friday!!!</div></div>
            </div>
          </div>
          <div class="cp-msg dim cp-msg-bot">
            <div class="cp-av"><img src="../Assets/Placeholder%20avatar.png" alt=""></div>
            <div><div class="cp-user">gowee</div><div class="cp-text">Hey friends!</div></div>
          </div>
        </div>
      </div>
      <div class="bs-texts">
        <div class="bs-title">Live Chat effect is online! 7 days access!</div>
        <div class="bs-desc">Stand out in the live chat with a special effect on your messages. Limited-time access — expires 7 days after purchase.</div>
      </div>
    </div>
    <div class="bs-tray">
      <button class="bs-btn" id="browseBtn">Browse now</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SCREEN 3: POST-PURCHASE
     ═══════════════════════════════════════ -->
<div class="scr" id="scrPP" style="display:flex;flex-direction:column">
  <div class="dark-bg"></div>

  <div class="echat">
    <div class="echat-inner">
      <div class="em muted"><div class="em-u">friend</div><div class="em-t white">yay! 🥳🥳🥳</div></div>
      <div class="em" id="ppMsgWrap">
        <div class="em-u">labubunation</div>
        <div class="em-t grad" id="ppMsg">Let's go!</div>
      </div>
      <div class="em muted"><div class="em-u">friend</div><div class="em-t white">Hey friends!</div></div>
    </div>
  </div>

  <div class="ebot">
    <div class="etabs-wrap">
      <div class="etab-indicator" id="ppIndicator"></div>
      <div class="etabs" id="ppTabs">
        <button class="etab on" data-e="gradient"><span class="etab-grad">Gradient</span></button>
        <button class="etab it" data-e="outline" data-text="Outline">Outline</button>
        <button class="etab" data-e="dynamic"><span class="etab-dyn"><span>Dynamic</span><span class="etab-sm"> font</span></span></button>
      </div>
    </div>
