    <div class="eexp">Expires: <span>7 days</span></div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SCREEN 4: TYPING
     ═══════════════════════════════════════ -->
<div class="scr" id="scrTS" style="display:flex;flex-direction:column">
  <div class="dark-bg"></div>
  <div class="enav">
    <button class="enav-back" id="tsBack"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="#fff" fill-rule="evenodd" d="M16.972 2.293a.97.97 0 0 1 0 1.414L8.333 12l8.639 8.293a.97.97 0 0 1 0 1.414c-.407.39-1.067.39-1.473 0L6.86 13.414a1.944 1.944 0 0 1 0-2.828L15.5 2.293a1.073 1.073 0 0 1 1.473 0" clip-rule="evenodd"/></svg></button>
    <div class="enav-title">Chat Effect</div>
    <div class="enav-gem"><img src="../Assets/Gem%20icon.png" alt="">120</div>
  </div>

  <div class="ts-area">
    <div class="ts-ph" id="tsPh">Type anything</div>
    <div class="ts-inp g-s" id="tsInp" contenteditable="true" spellcheck="false"></div>
  </div>

  <div class="ts-tabs" id="tsTabs" style="bottom:326px">
    <button class="etab on" data-e="gradient">Gradient</button>
    <button class="etab it" data-e="outline" data-text="Outline">Outline</button>
    <button class="etab" data-e="dynamic"><span class="etab-dyn"><span>Dynamic</span><span class="etab-sm"> font</span></span></button>
  </div>

  <div class="kb">
    <div class="kr">
      <div class="k">Q</div><div class="k">W</div><div class="k">E</div><div class="k">R</div><div class="k">T</div><div class="k">Y</div><div class="k">U</div><div class="k">I</div><div class="k">O</div><div class="k">P</div>
    </div>
    <div class="kr" style="padding:0 18px">
      <div class="k">A</div><div class="k">S</div><div class="k">D</div><div class="k">F</div><div class="k">G</div><div class="k">H</div><div class="k">J</div><div class="k">K</div><div class="k">L</div>
    </div>
    <div class="kr">
      <div class="k sp" style="min-width:46px">⇧</div>
      <div class="k">Z</div><div class="k">X</div><div class="k">C</div><div class="k">V</div><div class="k">B</div><div class="k">N</div><div class="k">M</div>
      <div class="k sp" style="min-width:46px">⌫</div>
    </div>
    <div class="kr">
      <div class="k sp">123</div>
      <div class="k" style="font-size:24px">😊</div>
      <div class="k spc">space</div>
      <div class="k dn" id="doneKey">Done</div>
    </div>
    <div class="kb-extra"><span style="cursor:pointer">☺</span><span style="cursor:pointer;color:#666">🎤</span></div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast">
  <div class="toast-ic" id="toastIc">Gr</div>
  <div>
    <div class="toast-tt" id="toastTt">You purchased Gradient!</div>
    <div class="toast-st">7 days only! Join a live now to show your effect!</div>
  </div>
</div>

<div id="transOverlay"></div>
</div><!-- /phone -->

<script>
const $ = s => document.querySelector(s);
const $$ = s => document.querySelectorAll(s);
const scrGS=$('#scrGS'),scrEP=$('#scrEP'),scrPP=$('#scrPP'),scrTS=$('#scrTS');
let curFx='gradient';

function go(scr){
  [scrGS,scrEP,scrPP,scrTS].forEach(s=>s.classList.remove('on'));
  scr.classList.add('on');
  const light=scr!==scrGS;
  $('#sbar').className=light?'sbar light':'sbar dark';
  $('#hind').className=light?'hind light':'hind dark';
}

/* Sheet */
function openSheet(){$('#ov').classList.add('on');$('#bsheet').classList.add('on')}
function closeSheet(){$('#ov').classList.remove('on');$('#bsheet').classList.remove('on')}

let sheetShown=false;
const phone=$('#app');
const transOverlay=$('#transOverlay');
let lastBannerRect=null;

function expandToDetail(){
  const banner=$('#ceBanner');
  const phoneRect=phone.getBoundingClientRect();
  const bannerRect=banner.getBoundingClientRect();

  const top=bannerRect.top-phoneRect.top;
  const left=bannerRect.left-phoneRect.left;
  const w=bannerRect.width;
  const h=bannerRect.height;

  lastBannerRect={top,left,w,h};

  const bg=document.createElement('div');
  bg.className='trans-bg';
  bg.style.cssText=`top:${top}px;left:${left}px;width:${w}px;height:${h}px;border-radius:16px`;
  bg.innerHTML='<div class="trans-dark" style="opacity:1"></div><div class="trans-blur" style="opacity:1"></div>';
  transOverlay.innerHTML='';
  transOverlay.appendChild(bg);
  transOverlay.classList.add('visible');

  void bg.offsetWidth;

  const dark=bg.querySelector('.trans-dark');
  const blur=bg.querySelector('.trans-blur');

  bg.style.top='0';
  bg.style.left='0';
  bg.style.width='100%';
  bg.style.height='100%';
  bg.style.borderRadius='0';
  dark.style.opacity='0';
  blur.style.opacity='0';

  bg.addEventListener('transitionend',function handler(e){
    if(e.propertyName!=='width')return;
    bg.removeEventListener('transitionend',handler);

    scrEP.classList.add('no-trans');
    go(scrEP);
    setTimeout(updateTabPadding,50);

    transOverlay.style.transition='opacity .15s ease';
    transOverlay.classList.remove('visible');
    setTimeout(()=>{
      transOverlay.innerHTML='';
      transOverlay.style.transition='';
      scrEP.classList.remove('no-trans');
    },160);
    if(!sheetShown){
      sheetShown=true;
      setTimeout(()=>openSheet(),300);
    }
  });
}

function collapseToStore(){
  closeSheet();
  const phoneRect=phone.getBoundingClientRect();

  transOverlay.innerHTML=`
    <div class="trans-bg" style="top:0;left:0;width:100%;height:100%;border-radius:0">
      <div class="trans-dark" style="opacity:0"></div>
      <div class="trans-blur" style="opacity:0"></div>
    </div>`;
  transOverlay.classList.add('visible');

  scrGS.classList.add('no-trans');
  go(scrGS);

  const bg=transOverlay.querySelector('.trans-bg');
  const dark=transOverlay.querySelector('.trans-dark');
  const blur=transOverlay.querySelector('.trans-blur');

  requestAnimationFrame(()=>{
    scrGS.classList.remove('no-trans');
    const freshBanner=$('#ceBanner');
    let targetRect=lastBannerRect||{top:300,left:16,w:361,h:186};
    if(freshBanner){
      const br=freshBanner.getBoundingClientRect();
      targetRect={
        top:br.top-phoneRect.top,
        left:br.left-phoneRect.left,
        w:br.width,
        h:br.height
      };
    }
    requestAnimationFrame(()=>{
      bg.style.cssText=`top:${targetRect.top}px;left:${targetRect.left}px;width:${targetRect.w}px;height:${targetRect.h}px;border-radius:16px;transition:all .35s cubic-bezier(0.4,0,0.2,1)`;
      dark.style.cssText='opacity:1;transition:opacity .35s cubic-bezier(0.4,0,0.2,1)';
      blur.style.cssText='opacity:1;transition:opacity .35s cubic-bezier(0.4,0,0.2,1)';
    });
  });

  bg.addEventListener('transitionend',function handler(e){
    if(e.propertyName!=='width')return;
    bg.removeEventListener('transitionend',handler);
    transOverlay.style.transition='opacity .15s ease';
    transOverlay.classList.remove('visible');
    setTimeout(()=>{
      transOverlay.innerHTML='';
      transOverlay.style.transition='';
    },160);
  });
}

$('#ceBanner').onclick=()=>expandToDetail();
$('#ov').onclick=closeSheet;
$('#browseBtn').onclick=()=>closeSheet();

/* Navigation */
$('#epBack').onclick=()=>collapseToStore();
$('#tsBack').onclick=()=>go(scrEP);
$('#doneKey').onclick=()=>go(scrEP);

/* Tab switching + snap-to-center */
function moveIndicator(tab,animate){
  const wrap=tab.closest('.etabs').parentElement;
  if(!wrap)return;
  const indicator=wrap.querySelector('.etab-indicator');
  if(!indicator)return;
  const w=Math.max(140,tab.offsetWidth);
  if(!animate)indicator.style.transition='none';
  indicator.style.width=w+'px';
  indicator.style.transform='translate(-50%,-50%)';
  if(!animate)requestAnimationFrame(()=>indicator.style.transition='');
}

function centerTab(tab){
  const container=tab.closest('.etabs');
  if(!container)return;
  const containerW=container.offsetWidth;
  container.scrollTo({left:tab.offsetLeft-containerW/2+tab.offsetWidth/2,behavior:'instant'});
}

function updateTabPadding(){
  $$('.etabs').forEach(container=>{
    const containerW=container.offsetWidth;
    const pad=containerW/2;
    container.style.paddingLeft=pad+'px';
    container.style.paddingRight=pad+'px';
    const active=container.querySelector('.etab.on,.etab-sw.on');
    if(active){centerTab(active);moveIndicator(active,false);}
  });
}
setTimeout(updateTabPadding,100);
window.addEventListener('resize',updateTabPadding);

function findCenterTab(container){
  const centerX=container.scrollLeft+container.offsetWidth/2;
  let closest=null,minDist=Infinity;
  container.querySelectorAll('.etab,.etab-sw').forEach(tab=>{
    const tabCenter=tab.offsetLeft+tab.offsetWidth/2;
    const dist=Math.abs(tabCenter-centerX);
    if(dist<minDist){minDist=dist;closest=tab}
  });
  return closest;
}

function selectTab(tab){
  if(!tab)return;
  const container=tab.closest('.etabs');
  container.querySelectorAll('.etab,.etab-sw').forEach(b=>b.classList.remove('on'));
  tab.classList.add('on');
  void tab.offsetWidth;
  moveIndicator(tab,true);
  if(tab.dataset.e){
    curFx=tab.dataset.e;
    renderPreview(true);
    renderTyping();
    if(typeof updatePurchaseUI==='function')updatePurchaseUI();
  }
}

$$('.etabs').forEach(container=>{
  let scrollTimer2=null;
  let lastNearestTab=null;
  container.addEventListener('scroll',()=>{
    const ct=findCenterTab(container);
    if(ct&&ct!==lastNearestTab){
      lastNearestTab=ct;
      container.querySelectorAll('.etab,.etab-sw').forEach(b=>b.classList.remove('on'));
      ct.classList.add('on');
      void ct.offsetWidth;
      moveIndicator(ct,true);
    }
    clearTimeout(scrollTimer2);
    scrollTimer2=setTimeout(()=>{
      const final=findCenterTab(container);
      if(final){
        if(!final.classList.contains('on')){
          container.querySelectorAll('.etab,.etab-sw').forEach(b=>b.classList.remove('on'));
          final.classList.add('on');
          void final.offsetWidth;
          moveIndicator(final,true);
        }
        centerTab(final);
        if(final.dataset.e&&curFx!==final.dataset.e){
          curFx=final.dataset.e;
          renderPreview(true);
          renderTyping();
          updatePurchaseUI();
        }
      }
      lastNearestTab=null;
    },150);
  },{passive:true});
});
setTimeout(()=>{
  $$('.etab-indicator').forEach(ind=>{
    ind.style.transform='translate(-50%,-50%)';
  });
},50);

document.addEventListener('click',e=>{
  const t=e.target.closest('.etab[data-e]');
  if(!t)return;
  selectTab(t);
  centerTab(t);
});

let userMsg='Happy Friday!!!';

function applyFxStyle(el,fx){
  el.className='em-t';
  el.removeAttribute('data-text');
  el.style.cssText='';
  if(fx==='gradient')el.classList.add('grad');
  else if(fx==='outline'){el.classList.add('outl');el.setAttribute('data-text',el.textContent)}
  else el.classList.add('white');
}

function renderPreview(animate){
  const msg=$('#epMsg');
  if(!msg)return;
  if(animate){
    const inner=$('.echat-inner');
    if(inner){
      inner.style.transition='opacity .25s ease-in-out';
      inner.style.opacity='0';
      setTimeout(()=>{
        msg.textContent=userMsg;
        applyFxStyle(msg,curFx);
        inner.style.opacity='1';
      },250);
    }
    return;
  }else{
    msg.textContent=userMsg;
    applyFxStyle(msg,curFx);
  }
}

function renderTyping(){
  const el=$('#tsInp');
  el.className='ts-inp';
  el.classList.add(curFx==='gradient'?'g-s':curFx==='outline'?'o-s':'d-s');
}

/* Buy */
function renderPostPurchase(){
  const wrap=$('#ppMsgWrap');
  if(!wrap)return;
  const msg="Let's go!";
  if(curFx==='gradient'){
    wrap.innerHTML=`<div class="em-u">labubunation</div><div class="em-t grad" id="ppMsg">${msg}</div>`;
  } else if(curFx==='outline'){
    wrap.innerHTML=`<div class="em-u">labubunation</div><div class="em-t outl" id="ppMsg" data-text="${msg}">${msg}</div>`;
  } else {
    wrap.innerHTML=`<div class="em-u">labubunation</div><div class="em-t inbox" id="ppMsg">${msg}</div>`;
  }
}
const purchased={};

function updatePurchaseUI(){
  const btn=$('#buyBtn');
  const disc=scrEP.querySelector('.edisc');
  if(purchased[curFx]){
    btn.style.visibility='hidden';
    disc.innerHTML='Expires: <span style="color:#34C759">7 days</span>';
    disc.style.color='rgba(255,255,255,0.35)';
  }else{
    btn.style.visibility='visible';
    disc.innerHTML='This chat effect will expire <span style="color:#34C759">7 days</span> after purchase.';
    disc.style.color='';
  }
}

$('#buyBtn').onclick=()=>{
  const gemEl=scrEP.querySelector('.enav-gem');
  const gemText=gemEl?gemEl.textContent.replace(/[^0-9]/g,''):'0';
  const gemCount=parseInt(gemText,10);
  const price=400;
  if(gemCount<price){
    alert('Not enough gems! You have '+gemCount+' but need '+price);
    return;
  }
  if(gemEl){
    const newBalance=gemCount-price;
    gemEl.innerHTML=gemEl.querySelector('img').outerHTML+newBalance;
  }
  purchased[curFx]=true;
  const nm={gradient:'Gradient',outline:'Outline',dynamic:'Dynamic Font'};
  const ab={gradient:'Gr',outline:'Ou',dynamic:'Dy'};
  $('#toastTt').textContent=`You purchased ${nm[curFx]||curFx}!`;
  $('#toastIc').textContent=ab[curFx]||'FX';
  updatePurchaseUI();
  setTimeout(()=>$('#toast').classList.add('show'),300);
  setTimeout(()=>$('#toast').classList.remove('show'),4000);
};

/* Keyboard */
$$('.k').forEach(k=>{
  k.addEventListener('click',e=>{
    e.stopPropagation();
    const inp=$('#tsInp'),ph=$('#tsPh'),t=k.textContent;
    if(k.classList.contains('dn')){go(scrEP);return}
    if(t==='⌫')inp.textContent=inp.textContent.slice(0,-1);
    else if(t==='⇧'||t==='123')return;
    else if(t==='space')inp.textContent+=' ';
    else inp.textContent+=t;
    ph.style.display=inp.textContent.length?'none':'';
  });
});
$('#tsInp').addEventListener('input',()=>{
  $('#tsPh').style.display=$('#tsInp').textContent.length?'none':'';
});

/* Edit mode on preview screen */
function enterEditMode(){
  scrEP.classList.add('editing');
  const msg=$('#epMsg');
  if(msg&&!msg.querySelector('.ep-cursor')){
    const cursor=document.createElement('span');
    cursor.className='ep-cursor';
    msg.appendChild(cursor);
  }
}
function exitEditMode(){
  const msg=$('#epMsg');
  if(msg){
    const cursor=msg.querySelector('.ep-cursor');
    if(cursor)cursor.remove();
    const txt=msg.textContent.trim();
    if(txt.length>0)userMsg=txt;
  }
  scrEP.classList.remove('editing');
  renderPreview();
}

document.addEventListener('click',e=>{
  if(!scrEP.classList.contains('on'))return;
  if(scrEP.classList.contains('editing')){
    if(!e.target.closest('.ep-kb')&&!e.target.closest('#epMsg')&&!e.target.closest('.etabs-wrap')){
      exitEditMode();
    }
    return;
  }
  const msg=e.target.closest('#epMsg');
  if(msg){enterEditMode();return}
});

$$('.ek').forEach(k=>{
  k.addEventListener('click',e=>{
    e.stopPropagation();
    const msg=$('#epMsg');
    if(!msg||!scrEP.classList.contains('editing'))return;
    const cursor=msg.querySelector('.ep-cursor');
    const t=k.textContent;
    if(k.classList.contains('dn')){exitEditMode();return}
    if(cursor)cursor.remove();
    if(t==='⌫'){msg.textContent=msg.textContent.slice(0,-1)}
    else if(t==='⇧'||t==='123'){/* no-op */}
    else if(t==='space')msg.textContent+=' ';
    else msg.textContent+=t;
    if(msg.dataset.text!==undefined)msg.setAttribute('data-text',msg.textContent);
    const nc=document.createElement('span');nc.className='ep-cursor';
    msg.appendChild(nc);
  });
});
</script>

</body>
</html>
